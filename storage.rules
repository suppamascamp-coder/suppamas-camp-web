rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // ต้องตั้ง custom claim admin=true ให้บัญชีแอดมินใน Firebase Auth
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Public read for website assets, admin-only upload/delete
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news_content/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /highlights/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /hero_slides/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /staff/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bases/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
