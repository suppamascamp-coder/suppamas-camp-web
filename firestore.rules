rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // ต้องตั้ง custom claim admin=true ให้บัญชีแอดมินใน Firebase Auth
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Public read, admin-only write for website content
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adventure_bases/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /packages/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
